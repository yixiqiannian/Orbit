# ============================================
# Orbit - 个人管理系统 环境变量配置
# ============================================
# 复制此文件为 .env 并填入你的实际配置
# cp .env.example .env

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=orbit

# ============================================
# JWT 配置
# ============================================
# 建议使用随机生成的密钥：python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ============================================
# Hermes Cron 配置
# ============================================
# Hermes Agent 的 API 地址和密钥
HERMES_API_URL=http://localhost:8080
HERMES_API_KEY=your-hermes-api-key

# ============================================
# 微信读书配置
# ============================================
# 获取方式：
# 1. 浏览器登录 https://weread.qq.com
# 2. F12 打开开发者工具 → Network
# 3. 刷新页面，找到任意请求
# 4. 复制请求头中的 Cookie 值
WEREAD_COOKIE=

# ============================================
# 应用配置
# ============================================
APP_PORT=8000
APP_DEBUG=false

# CORS 配置（前端地址，多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000

# ============================================
# 前端配置
# ============================================
VITE_API_BASE_URL=http://localhost:8000
